# FinGuard Environment Configuration
# Copy to .env and fill in your values

# ─── Application ─────────────────────────────────────────────
APP_NAME=FinGuard
APP_ENV=development          # development | production
APP_DEBUG=true
SECRET_KEY=finguard-secret-key
API_V1_PREFIX=/api/v1

# ─── MongoDB ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=finguard_db

# ─── Redis (alert cache & pub/sub) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ─── ML Models ──────────────────────────────────────────────
MODEL_DIR=./ml_models
ISOLATION_FOREST_CONTAMINATION=0.08
AUTOENCODER_THRESHOLD=0.42
RETRAIN_INTERVAL_HOURS=24

# ─── Risk Thresholds ────────────────────────────────────────
RISK_HIGH_THRESHOLD=0.65
RISK_MEDIUM_THRESHOLD=0.35
ALERT_AMOUNT_USD=10000       # CTR threshold

# ─── Anthropic (AI Analyst) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Frontend ───────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here
